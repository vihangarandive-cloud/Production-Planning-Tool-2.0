// /Views/ProductionOrder/Index.cshtml
@model IEnumerable<RPACProductionPlanner.Models.ProductionOrder>
@{
    ViewBag.Title = "Production Orders";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-bottom p-4 d-flex align-items-center">
        <div class="input-group w-50">
            <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
            <input type="text" id="orderSearch" class="form-control bg-light border-0 px-3" placeholder="Search by code, product or status...">
        </div>
        <div class="ms-auto">
            <a href="@Url.Action("Create")" class="btn btn-primary px-4 py-2 fw-semibold">
                <i class="bi bi-plus-lg me-2"></i> New Work Order
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle" id="ordersTable">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3">Order Code</th>
                        <th class="py-3">Product Name</th>
                        <th class="py-3">Quantity</th>
                        <th class="py-3">Planned Dates</th>
                        <th class="py-3">Status</th>
                        <th class="py-3">Priority</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 fw-medium">#@item.OrderCode</td>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity @item.UnitOfMeasure</td>
                            <td>
                                <div class="small fw-semibold">Start: @(item.PlannedStart?.ToString("MMM dd"))</div>
                                <div class="text-muted x-small">End: @(item.PlannedEnd?.ToString("MMM dd"))</div>
                            </td>
                            <td>
                                @{
                                    string statusClass = item.Status == "Completed" ? "bg-success-subtle text-success" : 
                                                         item.Status == "In Progress" ? "bg-primary-subtle text-primary" : 
                                                         item.Status == "On Hold" ? "bg-warning-subtle text-warning" : "bg-secondary-subtle text-secondary";
                                }
                                <span class="badge @statusClass border">@item.Status</span>
                            </td>
                            <td>
                                @{
                                    string priorityClass = item.Priority == "Urgent" ? "text-danger" : 
                                                           item.Priority == "High" ? "text-warning" : "text-muted";
                                }
                                <i class="bi bi-circle-fill @priorityClass me-1" style="font-size: 0.5rem;"></i> @item.Priority
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="@Url.Action("Details", new { id = item.OrderId })" class="btn btn-sm btn-light border me-2"><i class="bi bi-eye"></i></a>
                                    <button class="btn btn-sm btn-light border dropdown-toggle no-caret" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item" href="#" onclick="updateStatus(@item.OrderId, 'In Progress')">Start Production</a></li>
                                        <li><a class="dropdown-item" href="#" onclick="updateStatus(@item.OrderId, 'Completed')">Mark Completed</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" href="#">Delete</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
<script>
    function updateStatus(id, status) {
        $.post('@Url.Action("UpdateStatus")', { id: id, status: status }, function(res) {
            if (res.success) location.reload();
        });
    }

    $("#orderSearch").on("keyup", function() {
        var value = $(this).val().toLowerCase();
        $("#ordersTable tbody tr").filter(function() {
            $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
        });
    });
</script>
}
