// /Views/Account/Login.cshtml
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Login - RPAC Production Planner</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --rpac-blue: #1e3a8a;
            --rpac-red: #e11d48;
            --bg-main: #f8fafc;
        }
        body { 
            font-family: 'Inter', sans-serif; 
            background: linear-gradient(135deg, var(--rpac-blue) 0%, #0f172a 100%); 
            height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            margin: 0;
            overflow: hidden;
        }
        .login-card { 
            width: 100%; 
            max-width: 440px; 
            border: none; 
            border-radius: 2rem; 
            padding: 3rem;
            background: white;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .form-control {
            background-color: #f1f5f9;
            border: 2px solid transparent;
            border-radius: 1rem;
            padding: 0.8rem 1.2rem;
            transition: all 0.2s;
        }
        .form-control:focus {
            background-color: white;
            border-color: var(--rpac-red);
            box-shadow: 0 0 0 4px rgba(225, 29, 72, 0.1);
        }
        .btn-primary { 
            background-color: var(--rpac-red); 
            border: none; 
            border-radius: 1rem;
            padding: 0.8rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            box-shadow: 0 10px 15px -3px rgba(225, 29, 72, 0.3);
            transition: all 0.2s;
        }
        .btn-primary:hover {
            background-color: #be123c;
            transform: translateY(-2px);
        }
        .logo-img { height: 60px; margin-bottom: 1.5rem; object-contain: contain; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-5">
            <img src="https://storage.googleapis.com/static.antigravity.dev/cortex/8987019/rpac-logo.png" alt="RPAC Logo" class="logo-img" />
            <h4 class="fw-black text-dark mb-1 tracking-tight">PRODUCTION UNIT</h4>
            <p class="text-secondary small fw-bold uppercase tracking-widest">Enterprise Intelligence</p>
        </div>
        
        @if (ViewBag.Error != null) {
            <div class="alert alert-danger border-0 rounded-4 py-3 px-4 small mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("Login", "Account", FormMethod.Post)) {
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="form-label text-secondary small fw-black uppercase tracking-widest mb-2 px-1">Access Identity</label>
                <input type="text" name="username" class="form-control" placeholder="Unique User ID" required autofocus />
            </div>
            <div class="mb-5">
                <label class="form-label text-secondary small fw-black uppercase tracking-widest mb-2 px-1">Security Key</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-4">Authenticate</button>
        }

        <div class="text-center">
            <p class="text-muted" style="font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em;">
                SECURE ACCESS • SAP COMPATIBLE
            </p>
        </div>
    </div>
</body>
</html>
