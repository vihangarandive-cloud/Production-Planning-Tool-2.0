// /Views/Admin/Roles.cshtml
@{
    ViewBag.Title = "Role Permissions";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-bottom p-4">
        <h6 class="mb-0 fw-bold">System Roles</h6>
    </div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Role Name</th>
                    <th>Permissions Level</th>
                    <th class="text-end pe-4">Users</th>
                </tr>
            </thead>
            <tbody>
                <tr><td class="ps-4">Admin</td><td>Full System Control</td><td class="text-end pe-4">1</td></tr>
                <tr><td class="ps-4">Planner</td><td>Production & Scheduling</td><td class="text-end pe-4">2</td></tr>
                <tr><td class="ps-4">Supervisor</td><td>Shop Floor Tracking</td><td class="text-end pe-4">3</td></tr>
                <tr><td class="ps-4">Management</td><td>Read-only Reporting</td><td class="text-end pe-4">2</td></tr>
            </tbody>
        </table>
    </div>
</div>
