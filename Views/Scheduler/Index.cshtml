// /Views/Scheduler/Index.cshtml
@{
    ViewBag.Title = "Machine Scheduling (Gantt)";
}

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-white border-bottom p-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h6 class="mb-0 fw-bold">Machine Timeline</h6>
            </div>
            <div class="col-md-6 text-end">
                <div class="btn-group">
                    <button class="btn btn-sm btn-light border">Week</button>
                    <button class="btn btn-sm btn-primary border">Month</button>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body p-4" style="min-height: 400px;">
        <canvas id="ganttChart"></canvas>
    </div>
</div>

@section scripts {
<script>
    const ctx = document.getElementById('ganttChart').getContext('2d');
    
    // Mock data for Gantt visualization using horizontal bars
    const data = {
        labels: ['Vulcanizer A', 'Cutting M-1', 'Mixing Mill 2', 'Extruder Max', 'Hydraulic Press X'],
        datasets: [
            {
                label: 'PO-2026-001 (Shoes Alpha)',
                data: [
                    { x: ['2026-04-18', '2026-04-21'], y: 'Vulcanizer A' }
                ],
                backgroundColor: '#2563eb'
            },
            {
                label: 'PO-2026-002 (Belt V-Shape)',
                data: [
                    { x: ['2026-04-20', '2026-04-25'], y: 'Extruder Max' }
                ],
                backgroundColor: '#10b981'
            }
        ]
    };

    new Chart(ctx, {
        type: 'bar',
        data: data,
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: {
                    type: 'time',
                    time: { unit: 'day', displayFormats: { day: 'MMM dd' } },
                    min: '2026-04-15',
                    max: '2026-04-30'
                }
            },
            plugins: {
                tooltip: {
                    callbacks: {
                        label: function(context) { return context.dataset.label; }
                    }
                }
            }
        }
    });
</script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
}
